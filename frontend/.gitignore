# =====================================================
# ENVIRONMENT VARIABLES (DO NOT COMMIT)
# =====================================================

# Ignore all env files
.env
.env.*
*.env

# Allow example file
!.env.example

# Extra safety (nested folders)
**/.env
**/.env.*

# Explicit paths (optional but safe)
backend/.env
frontend/.env


# =====================================================
# PYTHON / FASTAPI
# =====================================================
__pycache__/
*.py[cod]
*$py.class

# virtual environments
venv/
env/
.venv/
ENV/

# Python build files
build/
dist/
*.egg-info/
.eggs/

# pytest / coverage
.pytest_cache/
.coverage
coverage.xml
htmlcov/

# local databases
*.db
*.sqlite3

# Jupyter notebooks
.ipynb_checkpoints

# =====================================================
# NODE / FRONTEND (VITE / REACT)
# =====================================================
node_modules/
dist/
dist-ssr/
.vite/
*.local

# logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# =====================================================
# EDITORS / IDE
# =====================================================
.vscode/*
!.vscode/extensions.json
.idea/

# JetBrains
*.iml

# Visual Studio
*.suo
*.ntvs*
*.njsproj
*.sln

# =====================================================
# OS FILES
# =====================================================
.DS_Store
Thumbs.db

# =====================================================
# TEMP FILES
# =====================================================
*.swp
*.swo
*.tmp
*.temp

# =====================================================
# CACHE
# =====================================================
.cache/
.pyre/
.mypy_cache/

# =====================================================
# MISC
# =====================================================
*.bak
*.orig


venv/
backend/venv/
node_modules/
.env